{
  "name": "bddb-next",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "meili:sync": "tsx scripts/syncMeilisearch.ts full",
    "meili:rebuild": "tsx scripts/syncMeilisearch.ts rebuild",
    "meili:stats": "tsx scripts/syncMeilisearch.ts stats",
    "meili:clear": "tsx scripts/syncMeilisearch.ts clear",
    "bangumi:sync": "tsx scripts/syncBangumiMeili.ts full",
    "bangumi:rebuild": "tsx scripts/syncBangumiMeili.ts rebuild",
    "bangumi:stats": "tsx scripts/syncBangumiMeili.ts stats",
    "bangumi:clear": "tsx scripts/syncBangumiMeili.ts clear",
    "electron:dev": "node electron-dev.js",
    "electron:build": "node electron/build.js",
    "electron:pack": "electron-builder --dir",
    "electron:dir": "npm run build && electron-builder --dir"
  },
  "build": {
    "appId": "com.bddb.app",
    "productName": "BDDB",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "!electron/build.js",
      "!electron-dev.js"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "server",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "public",
        "to": "server/public",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": ".next/static",
        "to": "server/.next/static",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icon.png"
    }
  },
  "dependencies": {
    "@ant-design/icons": "^6.0.0",
    "@ctrl/qbittorrent": "^9.11.2",
    "@types/mongodb": "^4.0.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "antd": "^6.3.1",
    "meilisearch": "^0.55.0",
    "mongodb": "^7.1.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "tsx": "^4.21.0"
  }
}
