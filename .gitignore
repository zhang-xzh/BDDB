# ========================================================================
# Next.js + TypeScript .gitignore
# ========================================================================

### --- 操作系统特定文件 (OS Junk) ---
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.fuse_hidden
*.swp
*~
.trash


### --- 常见编辑器与 IDE (IDEs & Editors) ---
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# JetBrains (IntelliJ, WebStorm, PyCharm, etc.)
.idea/
*.iws
*.iml
*.ipr
out/


### --- Next.js (重要!) ---
.next/
.out/
.vercel/


### --- Node.js ---
node_modules/
npm-debug.log*
yarn-error.log*
.pnpm-debug.log*
.eslintcache


### --- 敏感信息与环境变量 (Secrets - 重要!) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local


# 密钥文件
*.pem
*.key
*.cert
*.crt
*.pfx
*.p12


### --- 数据库与本地存储 ---
*.sqlite
*.sqlite-shm
*.sqlite-wal
*.db
.data/
*.nedb
data


### --- 日志、缓存与临时文件 ---
*.log
logs/
*.bak
*.tmp
*.temp
*.cache
/tsconfig.tsbuildinfo
